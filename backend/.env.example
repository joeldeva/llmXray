PORT=3001
ALLOWED_ORIGINS=*
COMPANY_NAME=LlmXray

# Development defaults are admin@llmxray.local / ChangeMe123! when these are omitted.
# Set all three before production.
# ADMIN_EMAIL=admin@company.example
# Generate with: node -e "console.log(require('./src/services/auth/authService').hashPassword('replace-with-real-password'))"
# ADMIN_PASSWORD_HASH=pbkdf2_sha256$120000$...
# JWT_SECRET=replace-with-at-least-32-random-bytes
ADMIN_TOKEN_TTL_SECONDS=28800

# Optional multi-user RBAC. Roles: admin, auditor, reviewer.
# ADMIN_USERS_JSON=[{"email":"admin@company.example","passwordHash":"pbkdf2_sha256$120000$...","role":"admin"},{"email":"audit@company.example","passwordHash":"pbkdf2_sha256$120000$...","role":"auditor"},{"email":"review@company.example","passwordHash":"pbkdf2_sha256$120000$...","role":"reviewer"}]

# Required bootstrap key for hosted APIs. Use this to generate llmxray_live_* keys.
# LLMXRAY_MASTER_API_KEY=replace-with-random-bootstrap-key
LLMXRAY_TENANT_ID=company-example
# If true, unknown API clients are rejected unless pre-registered/active.
LLMXRAY_ENFORCE_DEVICE_REGISTRY=false
LLMXRAY_DATA_DIR=./src/data

# Optional Postgres production storage. When omitted, local JSON storage is used.
# DATABASE_URL=postgres://llmxray:password@localhost:5432/llmxray
# DATABASE_SSL=false
AUDIT_RETENTION_DAYS=365

# Optional SIEM webhook export.
# SIEM_WEBHOOK_URL=https://siem.example.com/collector
# SIEM_WEBHOOK_TOKEN=replace-with-siem-token
# SIEM_TIMEOUT_MS=3000
